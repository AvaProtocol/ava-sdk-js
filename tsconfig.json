{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["tests", "examples", "config/**/*"],
  "ts-node": {
    "esm": true
  }
}
