{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/v4/index.ts"],
  "out": "docs-api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "externalPattern": ["**/node_modules/**", "**/@avaprotocol/types/**"],
  "sort": ["source-order"],
  "hideGenerator": true,
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "expandObjects": false,
  "expandParameters": true,
  "useCodeBlocks": true,
  "outputFileStrategy": "members",
  "entryFileName": "index",
  "fileExtension": ".mdx",
  "indexFormat": "table",
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "intentionallyNotExported": [
    "Transport",
    "ListExecutionsParams",
    "RetrieveExecutionParams",
    "CountExecutionsParams",
    "ExecutionStatsParams",
    "StreamExecutionParams",
    "ListSecretsParams",
    "DeleteSecretParams",
    "ListWorkflowsParams",
    "CountWorkflowsParams"
  ]
}
